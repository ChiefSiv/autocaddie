# ─────────────────────────────────────────────────────────────────────────────
# Autocaddie — environment variables
# Copy this file to `.env.local` and fill in real values. NEVER commit `.env.local`.
# `NEXT_PUBLIC_*` vars are exposed to the browser. Everything else is server-only.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────────────
# Project URL + anon key are safe for the client (RLS protects the data).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key bypasses RLS — SERVER ONLY. Never expose to the browser,
# never prefix with NEXT_PUBLIC_. Used for trusted server-side mutations
# (e.g. caching fetched course data into the DB).
SUPABASE_SERVICE_ROLE_KEY=

# ── Course data providers (server-only; behind the CourseDataProvider interface)
# Primary: GolfCourseAPI (golfcourseapi.com). Required for Phase 1 course lookup.
COURSE_API_KEY=
# Selects the active provider implementation. golfcourseapi | golfapi
COURSE_DATA_PROVIDER=golfcourseapi
# Fallback/upgrade: golfapi.io. Optional — only needed if/when we switch providers.
GOLFAPI_KEY=

# ── App / site URL ───────────────────────────────────────────────────────────
# Used for auth redirects, share links, and QR join codes. In production set to
# the deployed origin (e.g. https://autocaddie.com). In dev: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── OAuth (DEFERRED — email + guest only in Phase 0) ─────────────────────────
# Apple sign-in requires a paid Apple Developer account; add these once
# credentials + redirect URLs are configured in the Supabase Auth dashboard.
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
